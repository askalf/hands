{
  "name": "@askalf/hands",
  "version": "0.4.1",
  "description": "Cross-platform computer-use agent. Your LLM on your mouse, keyboard, and screen. Windows (PowerShell), macOS (open + osascript), Linux (xdotool / ydotool). Voice optional, safety guardrails. Routes through dario or any Anthropic-compat endpoint.",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "type": "module",
  "bin": {
    "hands": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "cheerio": "^1.2.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "inquirer": "^13.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-code": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-code": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "askalf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/askalf/hands.git"
  },
  "bugs": {
    "url": "https://github.com/askalf/hands/issues"
  },
  "homepage": "https://github.com/askalf/hands#readme",
  "keywords": [
    "ai",
    "agent",
    "computer-use",
    "claude",
    "anthropic",
    "automation",
    "voice-control",
    "cross-platform",
    "windows",
    "macos",
    "linux",
    "dario",
    "local"
  ]
}
